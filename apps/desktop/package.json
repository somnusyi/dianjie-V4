{
  "name": "@dianjie/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "滇界云管 Windows 桌面客户端（Tauri 外壳，复用 @dianjie/web 静态导出）",
  "scripts": {
    "build:web": "bash ../mobile/scripts/build-web-prod.sh",
    "copy:web": "rm -rf dist && cp -r ../web/out dist",
    "prepare:frontend": "pnpm build:web && pnpm copy:web",
    "tauri": "tauri",
    "dev": "pnpm prepare:frontend && tauri dev",
    "build": "pnpm prepare:frontend && tauri build",
    "build:msi": "pnpm prepare:frontend && tauri build --bundles msi",
    "build:nsis": "pnpm prepare:frontend && tauri build --bundles nsis"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  },
  "dependencies": {
    "@tauri-apps/plugin-updater": "^2.10.1"
  }
}
